{
  "manifest_version": 3,
  "name": "KidGuard - Child Online Grooming Detection",
  "version": "1.0.0",
  "description": "Protects children from online grooming on gaming platforms like Roblox",
  "permissions": [
    "storage",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://*.roblox.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.roblox.com/*"],
      "js": ["config.js", "detector.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
